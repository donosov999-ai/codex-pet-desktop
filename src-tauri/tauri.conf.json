{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Biruzik Desktop",
  "version": "0.2.31",
  "identifier": "com.odv999.biruzik",
  "build": {
    "frontendDist": "../src/app",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Biruzik",
        "url": "renderer.html",
        "width": 320,
        "height": 340,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "shadow": false,
        "backgroundColor": "#00000000",
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost http://asset.localhost https://donosov999-ai.github.io data:; connect-src 'self' https://api.github.com https://donosov999-ai.github.io; object-src 'none'; base-uri 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$RESOURCE/**",
          "$HOME/.codex/pets/**",
          "../resources/pets/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "useLocalToolsDir": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../resources/pets/biruzik": "pets/biruzik"
    },
    "windows": {}
  }
}
